# Required by /api/sync. Set both in the Vercel project's Environment
# Variables (Production + Preview + Development).
#
# Injected automatically by the Neon Vercel integration — no need to set by
# hand once the integration is connected.
DATABASE_URL=

# SHA-256 of your passphrase, hex-encoded. Generate locally with:
#   node -e "console.log(require('crypto').createHash('sha256').update('your long passphrase').digest('hex'))"
# The plaintext passphrase is what clients send as `Authorization: Bearer …`.
SYNC_PASS_HASH=
