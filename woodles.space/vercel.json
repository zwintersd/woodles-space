{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter write build && pnpm --filter marginalia build",
  "outputDirectory": ".",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                "destination": "/apps/landing/index.html" },
    { "source": "/fonts",           "destination": "/apps/fonts/index.html" },
    { "source": "/fonts/:path*",    "destination": "/apps/fonts/:path*" },
    { "source": "/palette",         "destination": "/apps/palette/index.html" },
    { "source": "/palette/:path*",  "destination": "/apps/palette/:path*" },
    { "source": "/motifs",          "destination": "/apps/motifs/index.html" },
    { "source": "/motifs/:path*",   "destination": "/apps/motifs/:path*" },
    { "source": "/scaffold",        "destination": "/apps/scaffold/index.html" },
    { "source": "/scaffold/:path*", "destination": "/apps/scaffold/:path*" },
    { "source": "/digits",          "destination": "/apps/digits/index.html" },
    { "source": "/digits/:path*",   "destination": "/apps/digits/:path*" },
    { "source": "/write",           "destination": "/apps/write/dist/index.html" },
    { "source": "/write/:path*",    "destination": "/apps/write/dist/:path*" },
    { "source": "/letter",          "destination": "/apps/letter/index.html" },
    { "source": "/letter/:path*",   "destination": "/apps/letter/:path*" },
    { "source": "/marginalia",         "destination": "/apps/marginalia/dist/index.html" },
    { "source": "/marginalia/:path*",  "destination": "/apps/marginalia/dist/:path*" }
  ]
}
