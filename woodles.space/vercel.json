{
  "buildCommand": "",
  "outputDirectory": ".",
  "routes": [
    { "src": "^/fonts/?$",    "dest": "/apps/fonts/index.html" },
    { "src": "^/fonts/(.+)$", "dest": "/apps/fonts/$1" },
    { "src": "^/write/?$",    "dest": "/apps/write/index.html" },
    { "src": "^/letter/?$",   "dest": "/apps/letter/index.html" },
    { "src": "^/$",           "dest": "/apps/landing/index.html" },
    { "src": "/(.*)",         "dest": "/$1" }
  ]
}
